# Discord OAuth — see https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=[GUILD-ID]
# For local: http://localhost:3000/api/auth/discord/callback
# For prod:  https://ftp-yyc-webring.vercel.app/api/auth/discord/callback
DISCORD_REDIRECT_URI=

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=

# Phase 2 — GitHub PR bot
# Create a fine-grained PAT scoped to jfran03/ftpyycring with permissions:
#   - Contents: Read & Write
#   - Pull requests: Read & Write
#   - Metadata: Read
# https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=
GITHUB_REPO_OWNER=jfran03
GITHUB_REPO_NAME=ftpyycring
# Optional: branch to read members.json from, fork submit branches off of, and open PRs into (default: main).
# Use your feature branch name locally while Phase 2 is unmerged: e.g. GITHUB_BASE_BRANCH=feat/submit-pr
# GITHUB_BASE_BRANCH=

# Phase 3+
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
